{
  "name": "marianum-next",
  "version": "0.1.0",
  "private": true,
  "license": "EUPL-1.2",
  "scripts": {
    "dev": "next dev",
    "develop": "npm run dev",
    "build": "next build",
    "start": "next start",
    "gen": "graphql-codegen && prettier --write graphql/index.ts",
    "lint": "eslint components pages utils",
    "lint:fix": "npm run lint -- --fix",
    "lint:quiet": "npm run lint -- --quiet",
    "prettier": "prettier --write .",
    "parse-translations": "i18next-cli extract",
    "update-react-aria": "npm install @internationalized/date@latest @react-stately/utils@latest react-aria@latest react-aria-components@latest react-stately@latest @react-aria/utils@latest tailwindcss-react-aria-components --save-exact --save-dev",
    "update-next": "npm install next@latest react@latest react-dom@latest sharp@latest --save-exact && npm install @types/react@latest @types/react-dom@latest eslint-config-next@latest typescript@latest @next/bundle-analyzer --save-dev --save-exact",
    "update-tailwind": "npm install tailwind-merge@latest clsx@latest --save-exact && npm install tailwindcss@latest postcss@latest prettier-plugin-tailwindcss@latest --save-dev --save-exact",
    "update-i18next": "npm install next-i18next@latest react-i18next@latest i18next@latest --save-exact && npm install i18next-parser@latest --save-dev --save-exact",
    "update-prettier": "npm install prettier@latest eslint-config-prettier@latest eslint-plugin-prettier@latest --save-dev --save-exact",
    "update-graphql": "npm install graphql@latest graphql-request@latest graphql-tag@latest --save-exact && npm install @graphql-codegen/cli@latest @graphql-codegen/typescript-graphql-request@latest --save-dev --save-exact"
  },
  "dependencies": {
    "@iframe-resizer/react": "5.5.5",
    "@internationalized/date": "3.10.1",
    "@react-aria/utils": "3.32.0",
    "@react-stately/toggle": "3.9.3",
    "@szhsin/react-menu": "3.5.3",
    "@tanstack/react-query": "5.77.2",
    "clsx": "2.1.1",
    "filesize": "9.0.11",
    "focus-trap-react": "11.0.3",
    "framer-motion": "12.26.1",
    "graphql": "16.10.0",
    "graphql-request": "6.1.0",
    "graphql-tag": "2.12.6",
    "i18next": "26.3.1",
    "lodash": "4.17.21",
    "mapbox-gl": "2.15.0",
    "meilisearch": "0.30.0",
    "next": "16.2.7",
    "next-i18next": "16.0.7",
    "nuqs": "2.4.3",
    "popmotion": "11.0.5",
    "prntr": "2.0.18",
    "react": "19.2.7",
    "react-aria": "3.38.1",
    "react-aria-components": "1.7.1",
    "react-dom": "19.2.7",
    "react-hook-form": "7.56.4",
    "react-i18next": "17.0.8",
    "react-map-gl": "7.1.9",
    "react-markdown": "10.0.1",
    "react-resize-detector": "12.0.2",
    "react-stately": "3.42.0",
    "react-turnstile": "1.1.4",
    "rehype-raw": "7.0.0",
    "remark-gfm": "4.0.1",
    "sharp": "0.35.0",
    "smooth-scroll-into-view-if-needed": "1.1.33",
    "swiper": "12.1.2",
    "tailwind-merge": "3.6.0",
    "tailwind-scrollbar-hide": "4.0.0",
    "tailwindcss-radix": "4.0.2",
    "tailwindcss-react-aria-components": "1.2.0",
    "usehooks-ts": "3.1.1",
    "yup": "0.32.11"
  },
  "devDependencies": {
    "@bratislava/eslint-config-next": "0.14.0",
    "@graphql-codegen/cli": "5.0.5",
    "@graphql-codegen/typescript": "4.1.5",
    "@graphql-codegen/typescript-graphql-request": "6.2.0",
    "@graphql-codegen/typescript-operations": "4.5.1",
    "@svgr/webpack": "6.2.1",
    "@tailwindcss/postcss": "4.3.0",
    "@types/lodash": "4.17.16",
    "@types/node": "24.13.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "i18next-cli": "latest",
    "lint-staged": "13.3.0",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "sass": "1.57.1",
    "tailwindcss": "4.3.0",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=24.16.x",
    "npm": ">=9.8.1"
  },
  "volta": {
    "node": "24.16.0"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
